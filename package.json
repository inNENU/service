{
  "name": "innenu-service",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/innenu/service.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "debug": "cross-env NODE_ENV=development pnpm build && cross-env NODE_ENV=development node dist/index.js --expose-gc",
    "dev": "tsdown -w",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@alicloud/alinlp20200629": "3.1.0",
    "@alicloud/openapi-client": "0.4.15",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@mptool/net": "0.14.0",
    "@mptool/parser": "0.14.0",
    "@mr-hope/tsconfig": "0.0.4",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/crypto-js": "4.2.2",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/morgan": "1.9.10",
    "@types/node": "24.13.2",
    "@types/qrcode": "1.5.6",
    "@types/qs": "6.15.1",
    "cheerio": "1.2.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "cross-env": "10.1.0",
    "crypto-js": "4.2.0",
    "domhandler": "^6.0.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "husky": "9.1.7",
    "iconv-lite": "0.7.2",
    "js-sha1": "0.7.0",
    "morgan": "1.11.0",
    "mysql2": "3.22.5",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "picocolors": "1.1.1",
    "qrcode": "1.5.4",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "uuid": "14.0.1"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.17.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": "^22.22.0 || ^24.17.0 || ^26.3.0"
  }
}

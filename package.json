{
  "name": "innenu-service",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/innenu/service.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "bundle:encrypt": "rollup -c scripts/encrypt.ts --configPlugin esbuild",
    "debug": "cross-env NODE_ENV=development pnpm build && cross-env NODE_ENV=development node dist/index.js --expose-gc",
    "dev": "tsdown -w",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@alicloud/alinlp20200629": "3.1.0",
    "@alicloud/openapi-client": "0.4.15",
    "@mptool/net": "0.12.0",
    "@mptool/parser": "0.12.0",
    "cheerio": "1.2.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "crypto-js": "4.2.0",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "iconv-lite": "0.7.2",
    "js-sha1": "0.7.0",
    "morgan": "1.10.1",
    "mysql2": "3.20.0",
    "picocolors": "1.1.1",
    "qrcode": "1.5.4",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@mr-hope/tsconfig": "0.0.3",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/crypto-js": "4.2.2",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/morgan": "1.9.10",
    "@types/node": "24.10.1",
    "@types/qrcode": "1.5.6",
    "@types/qs": "6.15.0",
    "cross-env": "10.1.0",
    "domhandler": "^5.0.3",
    "husky": "9.1.7",
    "nano-staged": "0.9.0",
    "npm-check-updates": "19.6.3",
    "oxc-config-hope": "0.0.8",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.17.0",
    "tsdown": "0.21.3",
    "typescript": "5.9.3",
    "unrun": "0.2.32"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">= 20.19"
  },
  "packageManager": "pnpm@10.32.1"
}
